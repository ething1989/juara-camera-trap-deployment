#!/usr/bin/env bash
set -u

if [ -f /etc/default/juara-gdrive-sync ]; then
  # shellcheck disable=SC1091
  . /etc/default/juara-gdrive-sync
fi

LOCAL_ROOT="${JUARA_LOCAL_ROOT:-/var/lib/juara-station/local}"
REMOTE_NAME="${JUARA_GDRIVE_REMOTE:-juara-gdrive}"
REMOTE_DIR="${JUARA_GDRIVE_DIR:-Julice Station/$(hostname)}"
LOG_PATH="${JUARA_GDRIVE_LOG:-/var/log/juara-gdrive-sync.log}"
LOCK_PATH="${JUARA_GDRIVE_LOCK:-/run/lock/juara-gdrive-sync.lock}"
TRANSFERS="${JUARA_GDRIVE_TRANSFERS:-1}"
CHECKERS="${JUARA_GDRIVE_CHECKERS:-2}"
RETRIES="${JUARA_GDRIVE_RETRIES:-8}"
LOW_LEVEL_RETRIES="${JUARA_GDRIVE_LOW_LEVEL_RETRIES:-30}"
RETRIES_SLEEP="${JUARA_GDRIVE_RETRIES_SLEEP:-2m}"
CONNECT_TIMEOUT="${JUARA_GDRIVE_CONNECT_TIMEOUT:-60s}"
IO_TIMEOUT="${JUARA_GDRIVE_IO_TIMEOUT:-10m}"

log() {
  printf '%s %s\n' "$(date -Is)" "$*" | tee -a "$LOG_PATH" >/dev/null
}

if ! command -v rclone >/dev/null 2>&1; then
  log "rclone is not installed"
  exit 0
fi

if [ ! -d "$LOCAL_ROOT" ]; then
  log "local station folder missing: $LOCAL_ROOT"
  exit 0
fi

if ! rclone listremotes 2>/dev/null | grep -qx "${REMOTE_NAME}:"; then
  log "remote ${REMOTE_NAME}: is not configured yet"
  exit 0
fi

if ! rclone about "${REMOTE_NAME}:" >/dev/null 2>&1; then
  log "remote ${REMOTE_NAME}: is configured but not logged in yet"
  exit 0
fi

mkdir -p "$(dirname "$LOCK_PATH")"
exec 9>"$LOCK_PATH"
if ! flock -n 9; then
  log "previous sync still running"
  exit 0
fi

log "starting copy to ${REMOTE_NAME}:${REMOTE_DIR}"
upload_filters=(
  --filter '- **/juara_environment_samples.csv'
  --filter '- **/juara_photo_diagnostics.csv'
  --filter '+ /logs/'
  --filter '+ /*.csv'
  --filter '+ /logs/*.csv'
  --filter '+ /media/'
  --filter '+ /media/survey_photos/**'
  --filter '+ /survey_photos/**'
  --filter '+ /SurveyPhotos/**'
  --filter '+ /Survey Photos/**'
)
upload_filters+=(--filter '- *')

rclone copy "$LOCAL_ROOT" "${REMOTE_NAME}:${REMOTE_DIR}" \
  --create-empty-src-dirs \
  --fast-list \
  --transfers "$TRANSFERS" \
  --checkers "$CHECKERS" \
  --retries "$RETRIES" \
  --low-level-retries "$LOW_LEVEL_RETRIES" \
  --retries-sleep "$RETRIES_SLEEP" \
  --contimeout "$CONNECT_TIMEOUT" \
  --timeout "$IO_TIMEOUT" \
  "${upload_filters[@]}" \
  --exclude '/.Spotlight-V100/**' \
  --exclude '/.Trashes/**' \
  --exclude '/.fseventsd/**' \
  --exclude '/System Volume Information/**' \
  --exclude '/$RECYCLE.BIN/**' \
  --exclude '._*' \
  --exclude '*.wav' \
  --exclude '*.tmp' \
  --exclude '*.part' \
  --log-file "$LOG_PATH" \
  --log-level INFO
status=$?
if [ "$status" -eq 0 ]; then
  log "sync complete"
else
  log "sync failed with status $status"
fi
exit 0
