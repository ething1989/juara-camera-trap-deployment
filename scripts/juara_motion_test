#!/usr/bin/env bash
set -u

SERVICE="juara-station.service"

restore_station() {
  echo
  echo "Restarting ${SERVICE}..."
  systemctl reset-failed "${SERVICE}" >/dev/null 2>&1 || true
  systemctl start "${SERVICE}" >/dev/null 2>&1 || true
  sleep 1
  echo "Station service: $(systemctl is-active "${SERVICE}" 2>/dev/null || true)"
}

trap restore_station EXIT INT TERM HUP

echo "Pausing ${SERVICE} so GPIO 26 is free for sensitivity testing..."
systemctl stop --no-block "${SERVICE}" >/dev/null 2>&1 || true
sleep 2

state="$(systemctl show "${SERVICE}" -p ActiveState --value 2>/dev/null || true)"
if [[ "${state}" == "active" || "${state}" == "activating" || "${state}" == "deactivating" ]]; then
  systemctl kill --kill-who=main --signal=KILL "${SERVICE}" >/dev/null 2>&1 || true
fi

for _ in {1..20}; do
  state="$(systemctl show "${SERVICE}" -p ActiveState --value 2>/dev/null || true)"
  [[ "${state}" != "active" && "${state}" != "activating" && "${state}" != "deactivating" ]] && break
  sleep 0.25
done

echo "Station paused. Starting live motion watcher."
echo
/usr/local/bin/juara-motion-trips "$@"
