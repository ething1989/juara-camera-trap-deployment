#!/usr/bin/env bash
set -u

if [ -f /etc/default/juara-networkpi-maintenance ]; then
  # shellcheck disable=SC1091
  . /etc/default/juara-networkpi-maintenance
fi

LOG_PATH="${JUARA_MAINTENANCE_LOG:-/var/log/juara-networkpi-maintenance.log}"
LOCK_PATH="${JUARA_MAINTENANCE_LOCK:-/run/lock/juara-networkpi-maintenance.lock}"
USB_MOUNT="${JUARA_USB_MOUNT:-/mnt/juara_usb}"
LOCAL_ROOT="${JUARA_LOCAL_ROOT:-/var/lib/juara-station/local}"
USB_ROOT="${JUARA_USB_ROOT:-/mnt/juara_usb/juara}"
STATE_DIR="${JUARA_STATE_DIR:-/var/lib/juara-station/state}"
SETUP_MARKER="${JUARA_SETUP_MARKER:-$STATE_DIR/setup-mode.active}"
SETUP_SSID="${JUARA_SETUP_SSID:-NetworkPi}"
SERVICE_REBOOT_TIMER="${JUARA_SERVICE_REBOOT_TIMER:-juara-service-hourly-reboot.timer}"
GIT_UPDATE_TIMEOUT_SECONDS="${JUARA_GIT_UPDATE_TIMEOUT_SECONDS:-300}"
GDRIVE_SYNC_TIMEOUT_SECONDS="${JUARA_GDRIVE_SYNC_TIMEOUT_SECONDS:-300}"
GDRIVE_SYNC_USER="${JUARA_GDRIVE_SYNC_USER:-}"

log() {
  printf '%s %s\n' "$(date -Is)" "$*" | tee -a "$LOG_PATH" >/dev/null
}

mkdir -p "$(dirname "$LOCK_PATH")"
exec 9>"$LOCK_PATH"
if ! flock -n 9; then
  log "previous maintenance pass still running"
  exit 0
fi

mount_usb() {
  mkdir -p "$USB_MOUNT"
  if findmnt -rn "$USB_MOUNT" >/dev/null 2>&1; then
    return 0
  fi
  if systemctl list-unit-files mnt-juara_usb.mount >/dev/null 2>&1; then
    systemctl start mnt-juara_usb.mount >/dev/null 2>&1 || true
  fi
  mount "$USB_MOUNT" >/dev/null 2>&1 || true
  findmnt -rn "$USB_MOUNT" >/dev/null 2>&1
}

unmount_usb() {
  sync
  if findmnt -rn "$USB_MOUNT" >/dev/null 2>&1; then
    umount "$USB_MOUNT" >/dev/null 2>&1 || log "USB unmount skipped; mount is busy"
  fi
}

copy_to_usb() {
  if [ ! -d "$LOCAL_ROOT" ]; then
    log "local station folder missing: $LOCAL_ROOT"
    return 0
  fi
  mkdir -p "$USB_ROOT"
  if command -v rsync >/dev/null 2>&1; then
    rsync -rltD --delete \
      --no-owner \
      --no-group \
      --no-perms \
      --delete-excluded \
      --exclude '**/juara_environment_samples.csv' \
      --exclude '**/juara_photo_diagnostics.csv' \
      --include '/*.csv' \
      --include '/logs/' \
      --include '/logs/*.csv' \
      --include '/reports/' \
      --include '/reports/***' \
      --include '/media/' \
      --include '/media/photos/***' \
      --include '/media/survey_photos/***' \
      --include '/Photos/***' \
      --include '/photos/***' \
      --include '/survey_photos/***' \
      --include '/SurveyPhotos/***' \
      --include '/Survey Photos/***' \
      --exclude '*' \
      "$LOCAL_ROOT"/ "$USB_ROOT"/ >>"$LOG_PATH" 2>&1
  else
    log "rsync is not installed; skipped USB export to avoid copying debug files"
    return 0
  fi
  log "USB export updated from $LOCAL_ROOT to $USB_ROOT"
}

run_with_timeout() {
  label="$1"
  seconds="$2"
  shift 2
  if command -v timeout >/dev/null 2>&1; then
    timeout --kill-after=30s "$seconds" "$@" >>"$LOG_PATH" 2>&1
  else
    "$@" >>"$LOG_PATH" 2>&1
  fi
  status=$?
  if [ "$status" -eq 124 ] || [ "$status" -eq 137 ]; then
    log "$label timed out after ${seconds}s"
  elif [ "$status" -ne 0 ]; then
    log "$label exited with status $status"
  else
    log "$label completed"
  fi
}

detect_gdrive_user() {
  if [ -n "$GDRIVE_SYNC_USER" ]; then
    printf '%s\n' "$GDRIVE_SYNC_USER"
    return 0
  fi
  for config in /home/*/.config/rclone/rclone.conf; do
    [ -s "$config" ] || continue
    basename "$(dirname "$(dirname "$(dirname "$config")")")"
    return 0
  done
  return 1
}

run_gdrive_sync() {
  sync_user="$(detect_gdrive_user || true)"
  if [ "$(id -u)" -eq 0 ] && [ -n "$sync_user" ] && id "$sync_user" >/dev/null 2>&1; then
    run_with_timeout \
      "Google Drive sync" \
      "$GDRIVE_SYNC_TIMEOUT_SECONDS" \
      sudo -u "$sync_user" env "HOME=/home/$sync_user" /usr/local/bin/juara_gdrive_sync
  else
    run_with_timeout "Google Drive sync" "$GDRIVE_SYNC_TIMEOUT_SECONDS" /usr/local/bin/juara_gdrive_sync
  fi
}

active_ssid="$(nmcli -t -f ACTIVE,SSID dev wifi 2>/dev/null | awk -F: '$1 == "yes" { print $2; exit }')"

if [ "$active_ssid" = "$SETUP_SSID" ]; then
  mkdir -p "$STATE_DIR"
  touch "$SETUP_MARKER"
  if systemctl list-unit-files "$SERVICE_REBOOT_TIMER" >/dev/null 2>&1; then
    systemctl enable --now "$SERVICE_REBOOT_TIMER" >/dev/null 2>&1 || true
    log "service mode active on $SETUP_SSID; $SERVICE_REBOOT_TIMER enabled"
  else
    log "service mode active on $SETUP_SSID"
  fi
else
  rm -f "$SETUP_MARKER"
  systemctl disable --now "$SERVICE_REBOOT_TIMER" >/dev/null 2>&1 || true
  log "run mode active; $SERVICE_REBOOT_TIMER disabled (active ssid: ${active_ssid:-none})"
fi

if mount_usb; then
  copy_to_usb
else
  log "USB is not mountable right now"
fi

if [ "$active_ssid" = "$SETUP_SSID" ]; then
  log "on $SETUP_SSID; running git update and Google Drive sync"
  run_with_timeout "git update" "$GIT_UPDATE_TIMEOUT_SECONDS" /usr/local/bin/juara_git_update
  run_gdrive_sync
else
  log "not on $SETUP_SSID; skipped git/Drive maintenance (active ssid: ${active_ssid:-none})"
fi

unmount_usb
