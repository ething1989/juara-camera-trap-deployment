#!/usr/bin/env bash
set -u

if [ -f /etc/default/juara-git-update ]; then
  # shellcheck disable=SC1091
  . /etc/default/juara-git-update
fi

LOG_PATH="${JUARA_GIT_UPDATE_LOG:-/var/log/juara-git-update.log}"
REPO_URL="${JUARA_GIT_REPO_URL:-https://github.com/ething1989/juara-camera-trap-deployment.git}"
CHECKOUT_DIR="${JUARA_GIT_CHECKOUT_DIR:-/var/lib/juara-station/git/juara-camera-trap-deployment}"
DEPLOY_DIR="${JUARA_GIT_DEPLOY_DIR:-/opt/juara-wildlife-station}"
BRANCH="${JUARA_GIT_BRANCH:-main}"

log() {
  printf '%s %s\n' "$(date -Is)" "$*" | tee -a "$LOG_PATH" >/dev/null
}

if ! command -v git >/dev/null 2>&1; then
  log "git is not installed"
  exit 0
fi

mkdir -p "$(dirname "$CHECKOUT_DIR")"
if [ ! -d "$CHECKOUT_DIR/.git" ]; then
  log "cloning $REPO_URL"
  rm -rf "$CHECKOUT_DIR"
  git clone --depth 1 --branch "$BRANCH" "$REPO_URL" "$CHECKOUT_DIR" >>"$LOG_PATH" 2>&1 || exit 0
else
  log "fetching $REPO_URL"
  git -C "$CHECKOUT_DIR" remote set-url origin "$REPO_URL" >>"$LOG_PATH" 2>&1 || true
  git -C "$CHECKOUT_DIR" fetch --depth 1 origin "$BRANCH" >>"$LOG_PATH" 2>&1 || exit 0
  current="$(git -C "$CHECKOUT_DIR" rev-parse HEAD 2>/dev/null || true)"
  incoming="$(git -C "$CHECKOUT_DIR" rev-parse "origin/$BRANCH" 2>/dev/null || true)"
  if [ -n "$current" ] && [ "$current" = "$incoming" ]; then
    log "already up to date at $current"
    exit 0
  fi
  git -C "$CHECKOUT_DIR" reset --hard "origin/$BRANCH" >>"$LOG_PATH" 2>&1 || exit 0
fi

if [ -d "$DEPLOY_DIR/.git" ]; then
  git -C "$DEPLOY_DIR" fetch --depth 1 "$CHECKOUT_DIR" "$BRANCH" >>"$LOG_PATH" 2>&1 || true
  git -C "$DEPLOY_DIR" reset --hard FETCH_HEAD >>"$LOG_PATH" 2>&1 || true
else
  rsync -a --delete \
    --exclude '.git' \
    --exclude '.venv' \
    "$CHECKOUT_DIR"/ "$DEPLOY_DIR"/ >>"$LOG_PATH" 2>&1 || true
fi

if [ -x "$DEPLOY_DIR/.venv/bin/python" ]; then
  "$DEPLOY_DIR/.venv/bin/python" -m pip install -e "$DEPLOY_DIR" >>"$LOG_PATH" 2>&1 || true
fi

systemctl restart juara-station.service juara-ai-worker.service >>"$LOG_PATH" 2>&1 || true
log "deployed field repo update"
